# Supabase settings (create a project and get these from the project settings)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 4-digit passcode to gate the app (defaults to 1234 if omitted)
VITE_PASSCODE=1234

# Notes:
# - Copy this file to .env.local or .env and replace the values.
# - Restart the dev server after changing env vars.
